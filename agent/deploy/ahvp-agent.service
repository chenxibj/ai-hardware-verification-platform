[Unit]
Description=AHVP Evaluation Agent
After=network.target
Documentation=https://github.com/chenxibj/ai-hardware-verification-platform
StartLimitIntervalSec=300
StartLimitBurst=5

[Service]
Type=simple
User=root
WorkingDirectory=/root/ahvp-agent
ExecStart=/usr/bin/python3 main.py
Restart=always
RestartSec=10
# OOM 保护：Agent 不应被 OOM killer 优先杀
OOMScoreAdjust=-500
# 环境变量文件
EnvironmentFile=-/root/ahvp-agent/.env
# 标准输出/错误走 journal
StandardOutput=journal
StandardError=journal
SyslogIdentifier=ahvp-agent

[Install]
WantedBy=multi-user.target
