{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ahvp.lab/schemas/eval_output.schema.json",
  "title": "AHVP Evaluation Script Output",
  "description": "JSON Schema for evaluation script output — defines required and optional fields for benchmark results (#521)",
  "type": "object",
  "required": ["benchmark_name", "results", "summary"],
  "properties": {
    "benchmark_name": {
      "type": "string",
      "description": "Name of the benchmark script"
    },
    "benchmark_version": {
      "type": "string",
      "description": "Version of the benchmark script"
    },
    "timestamp": {
      "type": "string",
      "description": "ISO 8601 timestamp of when the benchmark was run"
    },
    "system_info": {
      "type": "object",
      "description": "System information collected during benchmark"
    },
    "config": {
      "type": "object",
      "description": "Configuration used for the benchmark run"
    },
    "results": {
      "type": "array",
      "minItems": 1,
      "description": "Array of individual test results",
      "items": {
        "type": "object",
        "required": ["status"],
        "properties": {
          "status": {
            "type": "string",
            "enum": ["PASS", "FAIL", "WARN"],
            "description": "Test result status"
          },
          "latency_ms_mean": {
            "type": "number",
            "minimum": 0,
            "description": "Mean latency in milliseconds"
          },
          "throughput_ops": {
            "type": "number",
            "minimum": 0,
            "description": "Throughput in operations per second (alias: throughput_qps)"
          },
          "throughput_qps": {
            "type": "number",
            "minimum": 0,
            "description": "Throughput in queries per second"
          },
          "memory_peak_mb": {
            "type": "number",
            "minimum": 0,
            "description": "Peak memory usage in MB"
          },
          "accuracy": {
            "type": "number",
            "description": "Accuracy metric (0-1 or percentage)"
          },
          "loss": {
            "type": "number",
            "description": "Loss value from training"
          }
        },
        "additionalProperties": true
      }
    },
    "summary": {
      "type": "object",
      "description": "Summary statistics for the benchmark run",
      "required": ["passed", "failed"],
      "oneOf": [
        { "required": ["total_operators"] },
        { "required": ["total_tests"] },
        { "required": ["total_models"] }
      ],
      "properties": {
        "total_operators": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of operators tested"
        },
        "total_tests": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of tests (model inference)"
        },
        "total_models": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of models tested (training)"
        },
        "passed": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of passed tests"
        },
        "failed": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of failed tests"
        },
        "pass_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Pass rate as percentage"
        },
        "avg_latency_ms": {
          "type": "number",
          "minimum": 0,
          "description": "Average latency in milliseconds"
        },
        "avg_throughput_qps": {
          "type": "number",
          "minimum": 0,
          "description": "Average throughput in QPS"
        },
        "avg_throughput_samples_per_sec": {
          "type": "number",
          "minimum": 0,
          "description": "Average throughput in samples per second (training)"
        },
        "device": {
          "type": "string",
          "description": "Device used for benchmarking"
        }
      },
      "additionalProperties": true
    },
    "conclusion": {
      "type": "string",
      "description": "Human-readable conclusion of the benchmark"
    },
    "gpu_info": {
      "type": "object",
      "description": "GPU information if CUDA device was used"
    },
    "accuracy_results": {
      "type": "array",
      "description": "Detailed accuracy test results"
    },
    "custom_metrics": {
      "type": "object",
      "description": "Any additional custom metrics"
    }
  },
  "additionalProperties": true
}
