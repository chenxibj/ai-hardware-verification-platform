{
  "name": "ahvp-e2e-tests",
  "version": "1.0.0",
  "description": "BDD-style E2E tests for AI Hardware Verification Platform",
  "scripts": {
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:debug": "npx playwright test --debug",
    "test:ui": "npx playwright test --ui",
    "test:auth": "npx playwright test tests/features/auth.feature.spec.ts",
    "test:nav": "npx playwright test tests/features/navigation.feature.spec.ts",
    "test:lifecycle": "npx playwright test tests/features/task-lifecycle.feature.spec.ts",
    "test:templates": "npx playwright test tests/features/template-mgmt.feature.spec.ts",
    "test:ops": "npx playwright test tests/features/task-operations.feature.spec.ts",
    "report": "npx playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  }
}
